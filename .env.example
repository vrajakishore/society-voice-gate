# Azure Communication Services
ACS_CONNECTION_STRING=endpoint=https://YOUR_ACS.unitedstates.communication.azure.com/;accesskey=YOUR_KEY

# Azure AI Services — Voice Live API  (multi-service AIServices resource)
COGNITIVE_SERVICES_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
VOICE_LIVE_MODEL=gpt-4o-mini

# Azure OpenAI — ticket classification after call ends
# Can be the same endpoint as COGNITIVE_SERVICES_ENDPOINT
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# App
CALLBACK_HOST=https://YOUR-TUNNEL-OR-DOMAIN
LOG_LEVEL=INFO

# ── Authentication (pick ONE of the three modes below) ────────────────────────
#
# Mode 1: az login on host + mount ~/.azure in compose.yml (default for local dev)
#   No extra vars needed — DefaultAzureCredential reads ~/.azure automatically.
#
# Mode 2: Service Principal (works everywhere, recommended for CI/staging)
#   Create one: az ad sp create-for-rbac --name society-voice-gate --sdk-auth
#   Then assign the same RBAC roles from how-to-run.md Step 6 to the SP object ID.
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Mode 3: Managed Identity (Azure Container Apps / AKS only)
#   Deploy to Azure and assign the Cognitive Services User role to the managed identity.
#   No extra vars needed.
