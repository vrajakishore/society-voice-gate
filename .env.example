# ── Azure Communication Services ─────────────────────────────────────────────
ACS_CONNECTION_STRING=endpoint=https://YOUR_ACS.unitedstates.communication.azure.com/;accesskey=YOUR_KEY
ACS_PHONE_NUMBER=+1XXXXXXXXXX

# ── Azure AI Services (Cognitive Services endpoint for Voice Live API) ───────
COGNITIVE_SERVICES_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
VOICE_LIVE_MODEL=gpt-4o-mini

# ── Foundry Agent — fetches instructions & voice config from Foundry ─────────
# Create an agent in ai.azure.com → Agents, enable Voice mode, then fill these in.
# FOUNDRY_PROJECT_ENDPOINT = https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_AGENT_NAME=your-agent-name
FOUNDRY_PROJECT_ENDPOINT=https://YOUR_RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT

# ── Azure OpenAI — ticket classification after call ends ─────────────────────
# Can be the same endpoint as COGNITIVE_SERVICES_ENDPOINT when using AIServices.
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
CALLBACK_HOST=https://YOUR-DEVTUNNEL-OR-DOMAIN
LOG_LEVEL=INFO

# ── Authentication (pick ONE mode) ────────────────────────────────────────────
#
# Mode 1: az login (default for local dev)
#   No extra vars — compose.yml mounts ~/.azure read-only into the container.
#
# Mode 2: Service Principal (CI / staging)
#   az ad sp create-for-rbac --name society-voice-gate --role "Cognitive Services User" \
#     --scopes /subscriptions/<SUB_ID>/resourceGroups/<RG>
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Mode 3: Managed Identity (Container Apps / AKS)
#   Remove the ~/.azure volume mount from compose.yml.
#   Assign Cognitive Services User role to the managed identity.
#   No extra vars needed.
